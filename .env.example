# ---------------------------------------------------------------------------
# Proxmox MCP Server — example environment configuration
# Copy to `.env` (loaded automatically) or set these in your MCP client.
# Crafted by SoyRage Agency — https://soyrage.es/
# ---------------------------------------------------------------------------

# Proxmox VE API base URL. Include the scheme and the API port (8006).
# Examples: https://192.168.1.10:8006  ·  https://pve.lan:8006
PROXMOX_HOST=https://192.168.1.10:8006

# ----- Authentication ------------------------------------------------------
# RECOMMENDED: API token (Datacenter → Permissions → API Tokens).
#   PROXMOX_TOKEN_ID is "user@realm!tokenname", e.g. root@pam!mcp
#   PROXMOX_TOKEN_SECRET is the generated UUID.
PROXMOX_TOKEN_ID=root@pam!mcp
PROXMOX_TOKEN_SECRET=

# Alternative: username/password (ticket auth). Only used if no token is set.
#   PROXMOX_USER is "user@realm", e.g. root@pam
PROXMOX_USER=
PROXMOX_PASSWORD=

# ----- TLS -----------------------------------------------------------------
# Proxmox ships a self-signed certificate by default. Set to "true" only if
# your node presents a certificate your system trusts (e.g. via a CA / proxy).
PROXMOX_VERIFY_TLS=false

# ----- Safety controls -----------------------------------------------------
# When "true", every state-changing tool (start/stop/reboot/snapshot…) is
# disabled and the server exposes read-only insight only.
PROXMOX_MCP_READONLY=false

# When "true", the server serves realistic FABRICATED data (a 2-node lab with
# VMs, containers, storage and snapshots) so you can try it with NO real
# Proxmox host and no credentials. Great for demos and evaluation.
PROXMOX_MCP_DEMO=false

# Optional comma-separated allowlist of VMIDs (or names). When set, the server
# will only operate on matching guests. Empty = all. Example: 100,101,web
PROXMOX_MCP_ALLOWLIST=

# ----- Modular plugins -----------------------------------------------------
# Toggleable capability plugins. Names:
#   about (locked), nodes, guests, storage, tasks, cluster, snapshots, lifecycle
# Load ONLY these (comma-separated). Empty = load all.
PROXMOX_MCP_PLUGINS=
# Disable these regardless (comma-separated). 'about' cannot be disabled.
PROXMOX_MCP_DISABLED_PLUGINS=

# Log verbosity written to stderr: debug | info | warn | error
PROXMOX_MCP_LOG_LEVEL=info

# Optional path to a JSON config file (defaults to ./proxmox-mcp.config.json).
# PROXMOX_MCP_CONFIG=./proxmox-mcp.config.json
