{
  "name": "proxmox-mcp-server",
  "version": "1.0.0",
  "description": "Chat with your Proxmox VE cluster. A Model Context Protocol (MCP) server that lets any LLM list nodes, VMs and LXC containers, read status, manage lifecycle and take snapshots — safely. Built by SoyRage Agency.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "author": "SoyRage Agency (https://soyrage.es/)",
  "homepage": "https://soyrage.es/",
  "funding": {
    "type": "paypal",
    "url": "https://www.paypal.com/paypalme/soyrageagency"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proxmox",
    "proxmox-ve",
    "pve",
    "virtualization",
    "qemu",
    "lxc",
    "devops",
    "homelab",
    "self-hosted",
    "ai",
    "llm",
    "claude"
  ],
  "bin": {
    "proxmox-mcp-server": "dist/index.js",
    "proxmox-mcp-tui": "dist/tui/index.js",
    "proxmox-mcp-install": "scripts/install.mjs"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "tui": "node dist/tui/index.js",
    "tui:dev": "tsx src/tui/index.ts",
    "tui:demo": "node -e \"process.env.PROXMOX_MCP_DEMO='true';import('./dist/tui/index.js')\"",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "shots": "node scripts/tui-shot.mjs",
    "setup": "npm run build && node scripts/install.mjs",
    "install:claude": "node scripts/install.mjs",
    "smoke": "node scripts/smoke.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "playwright": "^1.61.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
